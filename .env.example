# Target API this MCP server exposes as tools.
# Petstore is a public sample API -- swap these for your real target API.
OPENAPI_URL=https://petstore.swagger.io/v2/swagger.json
API_BASE_URL=https://petstore.swagger.io/v2

# Optional. Bearer token used when calling protected endpoints on the target API.
OPENAPI_AUTH_TOKEN=

# Optional. Protects this MCP server itself -- if set, callers must send
# Authorization: Bearer <token>. Leave blank for local/unauthenticated testing.
MCP_AUTH_TOKEN=

# Optional. Comma-separated allowlist of IAM ARNs (exact, or wildcard like
# arn:aws:iam::123456789012:role/my-agent-*) allowed to authenticate instead of
# a bearer token, by sending Authorization: mcp-aws-v1.<base64 presigned
# sts:GetCallerIdentity URL> -- same pattern EKS uses for cluster auth tokens.
# Either a valid MCP_AUTH_TOKEN or a valid SigV4 identity satisfies auth.
SIGV4_ALLOWED_ARNS=

# Optional. Comma-separated allowlist of tool names to expose.
# Leave blank to expose every tool generated from the OpenAPI spec.
MCP_ALLOWED_TOOLS=

# Server bind settings -- defaults already match what Bedrock AgentCore Runtime expects.
PORT=8000
HOST=0.0.0.0
